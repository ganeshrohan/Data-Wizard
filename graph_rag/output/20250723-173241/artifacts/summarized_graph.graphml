    <node id="NETFLIX ANALYTICS SCHEMA">
      <data key="d0">CONCEPT</data>
      <data key="d1">Enhanced metadata framework for analyzing customer behavior, content performance, and revenue tracking, supporting Graph RAG traversal for natural language queries to SQL}</data>
      <data key="d2">6560620170abc6e57b18b7932d106d3f</data>
    </node>
    <node id="STREAMS">
      <data key="d0">CONCEPT</data>
      <data key="d1">Primary fact table recording atomic streaming events with aliases 'viewing_history' and 'plays'. Stores engagement metrics in Netflix.Consum database schema}</data>
