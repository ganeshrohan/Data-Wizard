      <data key="d5">Episode is a numerical attribute indicating the episode number (0 for movies)</data>
      <data key="d6">cffcda8a51675f1f2fce635cc560a247</data>
    </edge>
    <edge source="CONTENT" target="GENRE">
      <data key="d4">12.0</data>
      <data key="d5">Genre is a categorical attribute classifying the content type</data>
      <data key="d6">cffcda8a51675f1f2fce635cc560a247</data>
    </edge>
    <edge source="CONTENT" target="DURATION">
      <data key="d4">12.0</data>
      <data key="d5">Duration is a quantitative attribute measuring total runtime in minutes</data>
      <data key="d6">cffcda8a51675f1f2fce635cc560a247</data>
    </edge>
    <edge source="CONTENT" target="COST">
      <data key="d4">2.0</data>
      <data key="d5">Cost is a financial attribute representing the monetary value of the content</data>
      <data key="d6">cffcda8a51675f1f2fce635cc560a247</data>
    </edge>
    <edge source="INVOICE" target="INVOICE_NUMBER">
      <data key="d4">18.0</data>
      <data key="d5">Invoice number serves as unique identifier for billing records</data>
      <data key="d6">2c48c4a92d71155612fdbf70e9f0edc7</data>
    </edge>
    <edge source="INVOICE" target="CUSTOMER_ID">
      <data key="d4">18.0</data>
      <data key="d5">Customer ID links invoices to subscriber profiles for analysis</data>
      <data key="d6">2c48c4a92d71155612fdbf70e9f0edc7</data>
    </edge>
    <edge source="INVOICE" target="SIGN_UP_DATE">
      <data key="d4">18.0</data>
      <data key="d5">Sign-up date indicates when billing occurred for subscriptions</data>
      <data key="d6">2c48c4a92d71155612fdbf70e9f0edc7</data>
    </edge>
    <edge source="INVOICE" target="PLAN">
      <data key="d4">18.0</data>
      <data key="d5">Plan specifies subscription tier associated with billing records</data>
      <data key="d6">2c48c4a92d71155612fdbf70e9f0edc7</data>
    </edge>
    <edge source="INVOICE" target="SERVICE_PERIOD">
      <data key="d4">18.0</data>
      <data key="d5">Service period defines active duration covered by invoice</data>
      <data key="d6">2c48c4a92d71155612fdbf70e9f0edc7</data>
    </edge>
    <edge source="INVOICE" target="PAYMENT_METHOD">
      <data key="d4">18.0</data>
      <data key="d5">Payment method denotes financial instrument used for transaction</data>
      <data key="d6">2c48c4a92d71155612fdbf70e9f0edc7</data>
    </edge>
    <edge source="INVOICE" target="TOTAL">
      <data key="d4">18.0</data>
      <data key="d5">Total displays formatted monetary amount charged</data>
      <data key="d6">2c48c4a92d71155612fdbf70e9f0edc7</data>
    </edge>
    <edge source="INVOICE" target="TOTAL_NUMERIC">
      <data key="d4">18.0</data>
      <data key="d5">Total numeric enables quantitative analysis of revenue</data>
      <data key="d6">2c48c4a92d71155612fdbf70e9f0edc7</data>
    </edge>
    <edge source="INVOICE" target="SERVICE_START_DATE">
      <data key="d4">18.0</data>
      <data key="d5">Service start date is derived from service period for temporal analysis</data>
      <data key="d6">2c48c4a92d71155612fdbf70e9f0edc7</data>
    </edge>
    <edge source="INVOICE" target="SERVICE_END_DATE">
      <data key="d4">18.0</data>
      <data key="d5">Service end date is derived from service period for expiration tracking</data>
      <data key="d6">2c48c4a92d71155612fdbf70e9f0edc7</data>
    </edge>
    <edge source="STREAM_DURATION" target="STREAM">
      <data key="d4">18.0</data>
      <data key="d5">Stream duration is a measurable attribute of media streaming events</data>
      <data key="d6">2c48c4a92d71155612fdbf70e9f0edc7</data>
    </edge>
    <edge source="STREAM_RATING" target="STREAM">
      <data key="d4">18.0</data>
      <data key="d5">Stream rating captures user feedback for specific streaming sessions</data>
      <data key="d6">2c48c4a92d71155612fdbf70e9f0edc7</data>
    </edge>
    <edge source="STREAM" target="STREAM_TIMESTAMP">
      <data key="d4">18.0</data>
      <data key="d5">Stream timestamp precisely marks the initiation of playback events</data>
      <data key="d6">2c48c4a92d71155612fdbf70e9f0edc7</data>
    </edge>
    <edge source="NETFLIX" target="CONSUM">
      <data key="d4">16.0</data>
      <data key="d5">Netflix database system contains and hosts the Consum schema as a structural component</data>
      <data key="d6">cffcda8a51675f1f2fce635cc560a247</data>
    </edge>
    <edge source="GENRE" target="MEDIA_CONTENT">
      <data key="d4">20.0</data>
      <data key="d5">Genre is a categorical attribute that classifies the type of media content</data>
      <data key="d6">2d6bb29d3cb7bfcead920894c56c1262</data>
    </edge>
    <edge source="DURATION" target="MEDIA_CONTENT">
      <data key="d4">20.0</data>
      <data key="d5">Duration quantifies the runtime length of media content</data>
      <data key="d6">2d6bb29d3cb7bfcead920894c56c1262</data>
    </edge>
    <edge source="MEDIA_CONTENT" target="COST_PER_STREAM">
      <data key="d4">20.0</data>
      <data key="d5">Cost per stream represents the licensing fee associated with consuming media content</data>
      <data key="d6">2d6bb29d3cb7bfcead920894c56c1262</data>
    </edge>
    <edge source="MEDIA_CONTENT" target="RELEASE_DATE">
      <data key="d4">20.0</data>
      <data key="d5">Release date indicates the initial publication timeline of media content</data>
      <data key="d6">2d6bb29d3cb7bfcead920894c56c1262</data>
    </edge>
    <edge source="MEDIA_CONTENT" target="DISTRIBUTOR">
      <data key="d4">2.0</data>
      <data key="d5">Distributor identifies the rights management entity responsible for media content distribution</data>
